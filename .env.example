# ═══════════════════════════════════════════════════════════
#  Proyecto Programación — Sistema de Inventario
#  Archivo: .env  (copia esto como .env y edita los valores)
# ═══════════════════════════════════════════════════════════

# ── Base de datos PostgreSQL ─────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=inventario_db
DB_USER=postgres
DB_PASSWORD=TU_PASSWORD_AQUI

# ── Seguridad JWT ────────────────────────────────────────────
# Genera una clave larga y aleatoria. Ejemplo:
# python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=cambia_esta_clave_por_una_muy_larga_y_aleatoria

# ── Servidor ─────────────────────────────────────────────────
PORT=5000
DEBUG=true
